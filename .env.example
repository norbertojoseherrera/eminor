# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://eminor:eminor_dev@localhost:5432/eminor_db
DATABASE_TEST_URL=postgresql://eminor:eminor_dev@localhost:5433/eminor_test

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=change-me-run-openssl-rand-hex-32
JWT_REFRESH_SECRET=change-me-different-from-jwt-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Prescriptions signing ───────────────────────────────────
PRESCRIPTION_SIGNING_KEY=change-me-run-openssl-rand-hex-32

# ─── Cloudflare R2 ───────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=eminor-studies

# ─── Jitsi (opcional - meet.jit.si público no lo requiere) ───
JITSI_APP_ID=eminor
JITSI_APP_SECRET=change-me

# ─── App ─────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ─── Frontend (Next.js) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_JITSI_DOMAIN=meet.jit.si
